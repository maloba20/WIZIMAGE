# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wizimage

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# Create these prices in your Stripe dashboard (recurring monthly)
STRIPE_PRO_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_BUSINESS_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX

# ── AWS S3 / Cloudflare R2 ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_BUCKET_NAME=wizimage-uploads
AWS_REGION=us-east-1

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_API_KEY=SG.XXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@wizimage.com

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list
CORS_ORIGINS=["http://localhost:3000","https://wizimage.app"]
